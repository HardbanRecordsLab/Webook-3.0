# Konfiguracja środowiska (production/development)
NODE_ENV=production

# Port serwera backendu (domyślnie 3003)
PORT=3003

# Sekret do podpisywania tokenów JWT (dowolny długi ciąg znaków)
JWT_SECRET=zmien_mnie_na_bezpieczny_sekret

# URL połączenia z bazą danych PostgreSQL
# Format: postgresql://użytkownik:hasło@host:port/nazwa_bazy
DATABASE_URL=postgresql://postgres:TwojeHaslo@localhost:5432/webook_db

# Katalog na przesyłane pliki (względny lub bezwzględny)
UPLOAD_DIR=uploads

# Dozwolone domeny dla CORS (oddzielone przecinkami)
CORS_ORIGIN=http://localhost:8080,http://localhost:3000,https://webook.hardbanrecordslab.online

# ==================== AI KEYS (Wymagane do generowania treści) ====================

# GROQ (Zalecane - Najszybsze i darmowe limity)
# Pobierz klucz z: https://console.groq.com/keys
GROQ_API_KEY=gsk_...
XAI_API_KEY=xai-...

# GEMINI (Fallback - Opcja zapasowa)
# Pobierz klucz z: https://ai.google.dev/api
GEMINI_API_KEY=AIza...

# OPENAI (Opcjonalne)
OPENAI_API_KEY=sk-...

# ==================== TEXT-TO-SPEECH (Generowanie Audio) ====================

# ELEVENLABS (Opcjonalne - Najlepsza jakość głosu)
# Pobierz klucz z: https://elevenlabs.io
ELEVENLABS_API_KEY=...

# ==================== INNE USŁUGI ====================


# STRIPE (Płatności - Opcjonalne)
STRIPE_API_KEY=sk_test_...

# PAYPAL (Płatności - Opcjonalne)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

