{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DTR Assembly Manifest",
  "type": "object",
  "required": ["metadata", "sections"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "language": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "placeholders"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "order": { "type": "integer" },
          "placeholders": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\{\\{[A-Z0-9_\\-]+\\}\\}$"
            }
          }
        }
      }
    },
    "assets": {
      "type": "object",
      "properties": {
        "css": { "type": "array", "items": { "type": "string" } },
        "scripts": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
