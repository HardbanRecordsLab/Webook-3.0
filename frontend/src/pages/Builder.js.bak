import React, { useState, useEffect, useCallback, useRef } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { Button } from '../components/ui/button';
import { Input } from '../components/ui/input';
import { Label } from '../components/ui/label';
import { Textarea } from '../components/ui/textarea';
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter, DialogDescription } from '../components/ui/dialog';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '../components/ui/tabs';
import { ScrollArea } from '../components/ui/scroll-area';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '../components/ui/select';
import { Switch } from '../components/ui/switch';
import { toast } from 'sonner';
import { 
  ChevronLeft, Plus, Save, Eye, Download, Trash2, 
  GripVertical, FileText, HelpCircle, Settings, Upload,
  Image, Play, Loader2, BookOpen, Clock, Moon, Sun, Home,
  Volume2, PauseCircle, Bold, Italic, List, Link, Heading1, Heading2
} from 'lucide-react';
import { useTheme } from '../contexts/ThemeContext';
import { 
  getProject, updateProject, getChapters, createChapter, 
  updateChapter, deleteChapter, uploadPDF, exportWebbook,
  createQuiz, getQuiz
} from '../lib/api';

// Simple rich text editor component
const RichTextEditor = ({ value, onChange, placeholder }) => {
  const editorRef = useRef(null);
  
  const execCommand = (command, value = null) => {
    document.execCommand(command, false, value);
    if (editorRef.current) {
      onChange(editorRef.current.innerHTML);
    }
  };

  const handleInput = () => {
    if (editorRef.current) {
      onChange(editorRef.current.innerHTML);
    }
  };

  useEffect(() => {
    if (editorRef.current && editorRef.current.innerHTML !== value) {
      editorRef.current.innerHTML = value || '';
    }
  }, [value]);

  return (
    <div className="border border-border rounded-lg overflow-hidden bg-card">
      {/* Toolbar */}
      <div className="flex flex-wrap gap-1 p-2 border-b border-border bg-muted">
        <Button type="button" variant="ghost" size="sm" onClick={() => execCommand('bold')}>
          <Bold className="w-4 h-4" />
        </Button>
        <Button type="button" variant="ghost" size="sm" onClick={() => execCommand('italic')}>
          <Italic className="w-4 h-4" />
        </Button>
        <Button type="button" variant="ghost" size="sm" onClick={() => execCommand('formatBlock', 'h1')}>
          <Heading1 className="w-4 h-4" />
        </Button>
        <Button type="button" variant="ghost" size="sm" onClick={() => execCommand('formatBlock', 'h2')}>
          <Heading2 className="w-4 h-4" />
        </Button>
        <Button type="button" variant="ghost" size="sm" onClick={() => execCommand('insertUnorderedList')}>
          <List className="w-4 h-4" />
        </Button>
        <Button type="button" variant="ghost" size="sm" onClick={() => {
          const url = prompt('Enter URL:');
          if (url) execCommand('createLink', url);
        }}>
          <Link className="w-4 h-4" />
        </Button>
        <Button type="button" variant="ghost" size="sm" onClick={() => {
          const url = prompt('Enter image URL:');
          if (url) execCommand('insertImage', url);
        }}>
          <Image className="w-4 h-4" />
        </Button>
      </div>
      
      {/* Editor */}
      <div
        ref={editorRef}
        contentEditable
        onInput={handleInput}
        className="min-h-[400px] p-4 outline-none prose prose-slate dark:prose-invert max-w-none"
        style={{ lineHeight: 1.8 }}
        data-placeholder={placeholder}
      />
    </div>
  );
};

export default function Builder() {
  const { projectId } = useParams();
  const navigate = useNavigate();
  const { theme, toggleTheme } = useTheme();
  const fileInputRef = useRef(null);

  // State
  const [project, setProject] = useState(null);
  const [chapters, setChapters] = useState([]);
  const [selectedChapter, setSelectedChapter] = useState(null);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);
  const [newChapterOpen, setNewChapterOpen] = useState(false);
  const [newChapterTitle, setNewChapterTitle] = useState('');
  const [settingsOpen, setSettingsOpen] = useState(false);
  const [quizOpen, setQuizOpen] = useState(false);
  const [currentQuiz, setCurrentQuiz] = useState({ title: 'Quiz', questions: [] });

  // TTS State
  const [speaking, setSpeaking] = useState(false);
  const [ttsSupported, setTtsSupported] = useState(false);

  useEffect(() => {
    setTtsSupported('speechSynthesis' in window);
  }, []);

  const loadData = useCallback(async () => {
    try {
      const [projectRes, chaptersRes] = await Promise.all([
        getProject(projectId),
        getChapters(projectId)
      ]);
      setProject(projectRes.data);
      setChapters(chaptersRes.data);
      if (chaptersRes.data.length > 0) {
        setSelectedChapter(chaptersRes.data[0]);
      }
    } catch (error) {
      console.error('Failed to load project:', error);
      toast.error('Nie udało się załadować projektu');
    } finally {
      setLoading(false);
    }
  }, [projectId]);

  useEffect(() => {
    loadData();
  }, [loadData]);

  const handleSaveChapter = async () => {
    if (!selectedChapter) return;
    
    setSaving(true);
    try {
      await updateChapter(selectedChapter.id, {
        title: selectedChapter.title,
        content: selectedChapter.content,
        difficulty: selectedChapter.difficulty
      });
      toast.success('Zapisano!');
      
      setChapters(chapters.map(c => 
        c.id === selectedChapter.id ? selectedChapter : c
      ));
    } catch (error) {
      console.error('Failed to save:', error);
      toast.error('Nie udało się zapisać');
    } finally {
      setSaving(false);
    }
  };

  const handleCreateChapter = async () => {
    if (!newChapterTitle.trim()) {
      toast.error('Podaj tytuł rozdziału');
      return;
    }

    try {
      const res = await createChapter(projectId, {
        title: newChapterTitle,
        content: '<p>Rozpocznij pisanie...</p>',
        order: chapters.length
      });
      setChapters([...chapters, res.data]);
      setSelectedChapter(res.data);
      setNewChapterOpen(false);
      setNewChapterTitle('');
      toast.success('Rozdział utworzony!');
    } catch (error) {
      console.error('Failed to create chapter:', error);
      toast.error('Nie udało się utworzyć rozdziału');
    }
  };

  const handleDeleteChapter = async (chapterId) => {
    if (!window.confirm('Czy na pewno chcesz usunąć ten rozdział?')) return;

    try {
      await deleteChapter(chapterId);
      const newChapters = chapters.filter(c => c.id !== chapterId);
      setChapters(newChapters);
      if (selectedChapter?.id === chapterId) {
        setSelectedChapter(newChapters[0] || null);
      }
      toast.success('Rozdział usunięty');
    } catch (error) {
      console.error('Failed to delete chapter:', error);
      toast.error('Nie udało się usunąć rozdziału');
    }
  };

  const handlePdfUpload = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    try {
      toast.loading('Importowanie PDF...');
      const res = await uploadPDF(projectId, file);
      toast.dismiss();
      toast.success(`Zaimportowano ${res.data.chapters} rozdziałów!`);
      loadData();
    } catch (error) {
      toast.dismiss();
      toast.error('Nie udało się zaimportować PDF');
    }
  };

  const handleExport = async () => {
    try {
      const res = await exportWebbook(projectId);
      const blob = new Blob([res.data.html], { type: 'text/html' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = res.data.filename;
      a.click();
      URL.revokeObjectURL(url);
      toast.success('Webbook wyeksportowany!');
    } catch (error) {
      toast.error('Nie udało się wyeksportować');
    }
  };

  const handleTTS = () => {
    if (!ttsSupported || !selectedChapter) return;

    if (speaking) {
      window.speechSynthesis.cancel();
      setSpeaking(false);
      return;
    }

    const text = selectedChapter.content.replace(/<[^>]*>/g, ' ');
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'pl-PL';
    utterance.rate = 0.9;
    utterance.onend = () => setSpeaking(false);
    utterance.onerror = () => setSpeaking(false);
    
    window.speechSynthesis.speak(utterance);
    setSpeaking(true);
  };

  const handleSaveSettings = async () => {
    try {
      await updateProject(projectId, {
        title: project.title,
        description: project.description,
        settings: project.settings
      });
      toast.success('Ustawienia zapisane!');
      setSettingsOpen(false);
    } catch (error) {
      toast.error('Nie udało się zapisać ustawień');
    }
  };

  const openQuizEditor = async () => {
    if (!selectedChapter) return;
    
    try {
      const res = await getQuiz(selectedChapter.id);
      if (res.data) {
        setCurrentQuiz(res.data);
      } else {
        setCurrentQuiz({ title: 'Quiz', questions: [] });
      }
      setQuizOpen(true);
    } catch (error) {
      setCurrentQuiz({ title: 'Quiz', questions: [] });
      setQuizOpen(true);
    }
  };

  const addQuizQuestion = () => {
    const newQuestion = {
      id: crypto.randomUUID(),
      question: '',
      options: ['', '', '', ''],
      correct_answer: 0,
      explanation: ''
    };
    setCurrentQuiz({
      ...currentQuiz,
      questions: [...currentQuiz.questions, newQuestion]
    });
  };

  const updateQuizQuestion = (index, field, val) => {
    const newQuestions = [...currentQuiz.questions];
    newQuestions[index] = { ...newQuestions[index], [field]: val };
    setCurrentQuiz({ ...currentQuiz, questions: newQuestions });
  };

  const updateQuizOption = (qIndex, oIndex, val) => {
    const newQuestions = [...currentQuiz.questions];
    const newOptions = [...newQuestions[qIndex].options];
    newOptions[oIndex] = val;
    newQuestions[qIndex] = { ...newQuestions[qIndex], options: newOptions };
    setCurrentQuiz({ ...currentQuiz, questions: newQuestions });
  };

  const removeQuizQuestion = (index) => {
    setCurrentQuiz({
      ...currentQuiz,
      questions: currentQuiz.questions.filter((_, i) => i !== index)
    });
  };

  const saveQuiz = async () => {
    if (!selectedChapter) return;
    
    try {
      await createQuiz(selectedChapter.id, currentQuiz);
      toast.success('Quiz zapisany!');
      setQuizOpen(false);
    } catch (error) {
      toast.error('Nie udało się zapisać quizu');
    }
  };

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <Loader2 className="w-8 h-8 animate-spin text-primary" />
      </div>
    );
  }

  if (!project) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <p>Nie znaleziono projektu</p>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-background flex flex-col">
      {/* Top Bar */}
      <header className="h-14 border-b border-border bg-card flex items-center justify-between px-4 shrink-0">
        <div className="flex items-center gap-3">
          <Button variant="ghost" size="icon" onClick={() => navigate('/dashboard')} data-testid="back-btn">
            <ChevronLeft className="w-5 h-5" />
          </Button>
          <div className="flex items-center gap-2">
            <BookOpen className="w-4 h-4 text-primary" />
            <span className="font-medium truncate max-w-[200px]">{project.title}</span>
          </div>
        </div>

        <div className="flex items-center gap-2">
          <Button variant="ghost" size="icon" onClick={toggleTheme}>
            {theme === 'dark' ? <Sun className="w-4 h-4" /> : <Moon className="w-4 h-4" />}
          </Button>
          <Button variant="ghost" size="sm" onClick={() => setSettingsOpen(true)} data-testid="settings-btn">
            <Settings className="w-4 h-4 mr-2" /> Ustawienia
          </Button>
          <Button variant="outline" size="sm" onClick={() => navigate(`/preview/${projectId}`)} data-testid="preview-btn">
            <Eye className="w-4 h-4 mr-2" /> Podgląd
          </Button>
          <Button size="sm" onClick={handleExport} data-testid="export-btn">
            <Download className="w-4 h-4 mr-2" /> Eksportuj
          </Button>
        </div>
      </header>

      <div className="flex flex-1 overflow-hidden">
        {/* Left Sidebar - Chapters */}
        <aside className="w-64 border-r border-border bg-muted/30 flex flex-col shrink-0">
          <div className="p-3 border-b border-border flex items-center justify-between">
            <span className="text-sm font-medium text-muted-foreground uppercase tracking-wide">Rozdziały</span>
            <div className="flex gap-1">
              <Button variant="ghost" size="icon" className="h-7 w-7" onClick={() => fileInputRef.current?.click()} data-testid="import-pdf-btn">
                <Upload className="w-4 h-4" />
              </Button>
              <input 
                ref={fileInputRef}
                type="file" 
                accept=".pdf" 
                className="hidden" 
                onChange={handlePdfUpload}
              />
              <Button variant="ghost" size="icon" className="h-7 w-7" onClick={() => setNewChapterOpen(true)} data-testid="add-chapter-btn">
                <Plus className="w-4 h-4" />
              </Button>
            </div>
          </div>

          <ScrollArea className="flex-1">
            <div className="p-2 space-y-1">
              {chapters.length === 0 ? (
                <div className="p-4 text-center text-sm text-muted-foreground">
                  <FileText className="w-8 h-8 mx-auto mb-2 opacity-50" />
                  <p>Brak rozdziałów</p>
                  <Button 
                    variant="outline" 
                    size="sm" 
                    className="mt-2"
                    onClick={() => setNewChapterOpen(true)}
                  >
                    <Plus className="w-4 h-4 mr-1" /> Dodaj
                  </Button>
                </div>
              ) : (
                chapters.map((chapter, index) => (
                  <div
                    key={chapter.id}
                    className={`group flex items-center gap-2 p-2 rounded-md cursor-pointer transition-colors ${
                      selectedChapter?.id === chapter.id 
                        ? 'bg-primary text-primary-foreground' 
                        : 'hover:bg-accent'
                    }`}
                    onClick={() => setSelectedChapter(chapter)}
                    data-testid={`chapter-item-${index}`}
                  >
                    <GripVertical className="w-4 h-4 opacity-50" />
                    <div className="flex-1 min-w-0">
                      <p className="text-sm font-medium truncate">{chapter.title}</p>
                      <p className={`text-xs ${selectedChapter?.id === chapter.id ? 'opacity-70' : 'text-muted-foreground'}`}>
                        <Clock className="w-3 h-3 inline mr-1" />
                        {chapter.reading_time || 1} min
                      </p>
                    </div>
                    <Button
                      variant="ghost"
                      size="icon"
                      className={`h-6 w-6 opacity-0 group-hover:opacity-100 ${selectedChapter?.id === chapter.id ? 'hover:bg-primary-foreground/20' : ''}`}
                      onClick={(e) => { e.stopPropagation(); handleDeleteChapter(chapter.id); }}
                    >
                      <Trash2 className="w-3 h-3" />
                    </Button>
                  </div>
                ))
              )}
            </div>
          </ScrollArea>
        </aside>

        {/* Main Content - Editor */}
        <main className="flex-1 flex flex-col overflow-hidden">
          {selectedChapter ? (
            <>
              {/* Chapter Header */}
              <div className="p-4 border-b border-border flex items-center justify-between">
                <div className="flex-1 mr-4">
                  <Input 
                    value={selectedChapter.title}
                    onChange={(e) => setSelectedChapter({...selectedChapter, title: e.target.value})}
                    className="text-lg font-heading font-semibold border-none shadow-none px-0 focus-visible:ring-0"
                    placeholder="Tytuł rozdziału"
                    data-testid="chapter-title-input"
                  />
                </div>
                <div className="flex items-center gap-2">
                  <Select 
                    value={selectedChapter.difficulty || 'beginner'}
                    onValueChange={(v) => setSelectedChapter({...selectedChapter, difficulty: v})}
                  >
                    <SelectTrigger className="w-32 h-8">
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="beginner">Łatwy</SelectItem>
                      <SelectItem value="intermediate">Średni</SelectItem>
                      <SelectItem value="advanced">Trudny</SelectItem>
                    </SelectContent>
                  </Select>
                  {ttsSupported && (
                    <Button 
                      variant="outline" 
                      size="sm"
                      onClick={handleTTS}
                      data-testid="tts-btn"
                    >
                      {speaking ? <PauseCircle className="w-4 h-4 mr-1" /> : <Volume2 className="w-4 h-4 mr-1" />}
                      {speaking ? 'Stop' : 'Czytaj'}
                    </Button>
                  )}
                  <Button 
                    variant="outline" 
                    size="sm"
                    onClick={openQuizEditor}
                    data-testid="quiz-btn"
                  >
                    <HelpCircle className="w-4 h-4 mr-1" /> Quiz
                  </Button>
                  <Button 
                    size="sm"
                    onClick={handleSaveChapter}
                    disabled={saving}
                    data-testid="save-chapter-btn"
                  >
                    {saving ? <Loader2 className="w-4 h-4 mr-1 animate-spin" /> : <Save className="w-4 h-4 mr-1" />}
                    Zapisz
                  </Button>
                </div>
              </div>

              {/* Editor */}
              <div className="flex-1 overflow-auto p-4">
                <div className="max-w-4xl mx-auto">
                  <RichTextEditor
                    value={selectedChapter.content}
                    onChange={(content) => setSelectedChapter({...selectedChapter, content})}
                    placeholder="Zacznij pisać treść rozdziału..."
                  />
                </div>
              </div>
            </>
          ) : (
            <div className="flex-1 flex items-center justify-center text-muted-foreground">
              <div className="text-center">
                <FileText className="w-16 h-16 mx-auto mb-4 opacity-30" />
                <p className="text-lg">Wybierz lub utwórz rozdział</p>
                <Button 
                  variant="outline" 
                  className="mt-4"
                  onClick={() => setNewChapterOpen(true)}
                >
                  <Plus className="w-4 h-4 mr-2" /> Nowy rozdział
                </Button>
              </div>
            </div>
          )}
        </main>
      </div>

      {/* New Chapter Dialog */}
      <Dialog open={newChapterOpen} onOpenChange={setNewChapterOpen}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Nowy rozdział</DialogTitle>
            <DialogDescription>Dodaj nowy rozdział do webbooka</DialogDescription>
          </DialogHeader>
          <div className="py-4">
            <Label htmlFor="chapterTitle">Tytuł rozdziału</Label>
            <Input 
              id="chapterTitle"
              value={newChapterTitle}
              onChange={(e) => setNewChapterTitle(e.target.value)}
              placeholder="np. Dzień 1: Wprowadzenie"
              data-testid="new-chapter-title-input"
            />
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setNewChapterOpen(false)}>Anuluj</Button>
            <Button onClick={handleCreateChapter} data-testid="create-chapter-btn">
              <Plus className="w-4 h-4 mr-2" /> Utwórz
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Settings Dialog */}
      <Dialog open={settingsOpen} onOpenChange={setSettingsOpen}>
        <DialogContent className="max-w-xl">
          <DialogHeader>
            <DialogTitle>Ustawienia projektu</DialogTitle>
            <DialogDescription>Dostosuj wygląd i funkcje webbooka</DialogDescription>
          </DialogHeader>
          
          <Tabs defaultValue="general">
            <TabsList className="grid w-full grid-cols-3">
              <TabsTrigger value="general">Ogólne</TabsTrigger>
              <TabsTrigger value="design">Wygląd</TabsTrigger>
              <TabsTrigger value="features">Funkcje</TabsTrigger>
            </TabsList>

            <TabsContent value="general" className="space-y-4 py-4">
              <div>
                <Label>Tytuł projektu</Label>
                <Input 
                  value={project.title}
                  onChange={(e) => setProject({...project, title: e.target.value})}
                />
              </div>
              <div>
                <Label>Opis</Label>
                <Textarea 
                  value={project.description}
                  onChange={(e) => setProject({...project, description: e.target.value})}
                  rows={3}
                />
              </div>
            </TabsContent>

            <TabsContent value="design" className="space-y-4 py-4">
              <div className="grid grid-cols-2 gap-4">
                <div>
                  <Label>Kolor główny</Label>
                  <div className="flex gap-2 mt-1">
                    <input 
                      type="color" 
                      value={project.settings?.primary_color || '#14532D'}
                      onChange={(e) => setProject({
                        ...project, 
                        settings: {...project.settings, primary_color: e.target.value}
                      })}
                      className="w-10 h-10 rounded cursor-pointer"
                    />
                    <Input 
                      value={project.settings?.primary_color || '#14532D'}
                      onChange={(e) => setProject({
                        ...project, 
                        settings: {...project.settings, primary_color: e.target.value}
                      })}
                    />
                  </div>
                </div>
                <div>
                  <Label>Kolor akcentu</Label>
                  <div className="flex gap-2 mt-1">
                    <input 
                      type="color" 
                      value={project.settings?.accent_color || '#A27B5C'}
                      onChange={(e) => setProject({
                        ...project, 
                        settings: {...project.settings, accent_color: e.target.value}
                      })}
                      className="w-10 h-10 rounded cursor-pointer"
                    />
                    <Input 
                      value={project.settings?.accent_color || '#A27B5C'}
                      onChange={(e) => setProject({
                        ...project, 
                        settings: {...project.settings, accent_color: e.target.value}
                      })}
                    />
                  </div>
                </div>
              </div>
            </TabsContent>

            <TabsContent value="features" className="space-y-4 py-4">
              <div className="flex items-center justify-between">
                <div>
                  <Label>Pasek postępu</Label>
                  <p className="text-sm text-muted-foreground">Pokazuj postęp nauki</p>
                </div>
                <Switch 
                  checked={project.settings?.show_progress !== false}
                  onCheckedChange={(v) => setProject({
                    ...project, 
                    settings: {...project.settings, show_progress: v}
                  })}
                />
              </div>
              <div className="flex items-center justify-between">
                <div>
                  <Label>Spis treści</Label>
                  <p className="text-sm text-muted-foreground">Pokazuj sidebar z rozdziałami</p>
                </div>
                <Switch 
                  checked={project.settings?.show_toc !== false}
                  onCheckedChange={(v) => setProject({
                    ...project, 
                    settings: {...project.settings, show_toc: v}
                  })}
                />
              </div>
              <div className="flex items-center justify-between">
                <div>
                  <Label>Text-to-Speech</Label>
                  <p className="text-sm text-muted-foreground">Odczytywanie treści</p>
                </div>
                <Switch 
                  checked={project.settings?.enable_tts !== false}
                  onCheckedChange={(v) => setProject({
                    ...project, 
                    settings: {...project.settings, enable_tts: v}
                  })}
                />
              </div>
              <div className="flex items-center justify-between">
                <div>
                  <Label>Zakładki</Label>
                  <p className="text-sm text-muted-foreground">Użytkownicy mogą zapisywać rozdziały</p>
                </div>
                <Switch 
                  checked={project.settings?.enable_bookmarks !== false}
                  onCheckedChange={(v) => setProject({
                    ...project, 
                    settings: {...project.settings, enable_bookmarks: v}
                  })}
                />
              </div>
            </TabsContent>
          </Tabs>

          <DialogFooter>
            <Button variant="outline" onClick={() => setSettingsOpen(false)}>Anuluj</Button>
            <Button onClick={handleSaveSettings}>Zapisz ustawienia</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Quiz Editor Dialog */}
      <Dialog open={quizOpen} onOpenChange={setQuizOpen}>
        <DialogContent className="max-w-2xl max-h-[80vh] overflow-y-auto">
          <DialogHeader>
            <DialogTitle>Edytor Quizu</DialogTitle>
            <DialogDescription>Dodaj pytania do rozdziału</DialogDescription>
          </DialogHeader>

          <div className="space-y-4 py-4">
            <div>
              <Label>Tytuł quizu</Label>
              <Input 
                value={currentQuiz.title}
                onChange={(e) => setCurrentQuiz({...currentQuiz, title: e.target.value})}
                placeholder="Quiz sprawdzający"
              />
            </div>

            <div className="space-y-4">
              {currentQuiz.questions.map((q, qIndex) => (
                <Card key={q.id}>
                  <CardHeader className="pb-2">
                    <CardTitle className="text-sm flex items-center justify-between">
                      Pytanie {qIndex + 1}
                      <Button 
                        variant="ghost" 
                        size="icon" 
                        className="h-6 w-6"
                        onClick={() => removeQuizQuestion(qIndex)}
                      >
                        <Trash2 className="w-3 h-3" />
                      </Button>
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="space-y-3">
                    <Textarea 
                      value={q.question}
                      onChange={(e) => updateQuizQuestion(qIndex, 'question', e.target.value)}
                      placeholder="Treść pytania"
                      rows={2}
                    />
                    <div className="space-y-2">
                      {q.options.map((opt, oIndex) => (
                        <div key={oIndex} className="flex items-center gap-2">
                          <input 
                            type="radio"
                            name={`correct-${qIndex}`}
                            checked={q.correct_answer === oIndex}
                            onChange={() => updateQuizQuestion(qIndex, 'correct_answer', oIndex)}
                          />
                          <Input 
                            value={opt}
                            onChange={(e) => updateQuizOption(qIndex, oIndex, e.target.value)}
                            placeholder={`Odpowiedź ${oIndex + 1}`}
                            className="flex-1"
                          />
                        </div>
                      ))}
                    </div>
                    <div>
                      <Label className="text-xs">Wyjaśnienie (po odpowiedzi)</Label>
                      <Input 
                        value={q.explanation}
                        onChange={(e) => updateQuizQuestion(qIndex, 'explanation', e.target.value)}
                        placeholder="Opcjonalne wyjaśnienie"
                      />
                    </div>
                  </CardContent>
                </Card>
              ))}
            </div>

            <Button variant="outline" onClick={addQuizQuestion} className="w-full">
              <Plus className="w-4 h-4 mr-2" /> Dodaj pytanie
            </Button>
          </div>

          <DialogFooter>
            <Button variant="outline" onClick={() => setQuizOpen(false)}>Anuluj</Button>
            <Button onClick={saveQuiz} data-testid="save-quiz-btn">
              <Save className="w-4 h-4 mr-2" /> Zapisz quiz
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}
