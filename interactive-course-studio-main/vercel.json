{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://84.247.162.167:3003/api/$1" },
    { "source": "/uploads/(.*)", "destination": "http://84.247.162.167:3003/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
